<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Product Dashboard - NNPTUD-S3</title>
  <!-- Bootstrap 5 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/stylesheets/dashboard.css" />
</head>

<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid px-4">
      <a class="navbar-brand d-flex align-items-center gap-2" href="#">
        <i class="bi bi-shop fs-4 text-primary"></i>
        <span class="fw-700">NNPTUD-<span class="text-primary">S3</span></span>
      </a>
      <div class="d-flex align-items-center gap-3 ms-auto">
        <span class="badge bg-light text-dark px-3 py-2" id="totalBadge">
          <i class="bi bi-box-seam me-1"></i> Loading...
        </span>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="container-fluid px-4 py-4">

    <!-- Header Card -->
    <div class="bg-white rounded-4 shadow-sm p-4 mb-4 border">
      <div class="row align-items-center">
        <div class="col-md-6">
          <h2 class="mb-1 fw-700 text-dark"><i class="bi bi-grid-3x3-gap-fill me-2 text-primary"></i>Product Dashboard
          </h2>
          <p class="text-muted mb-0">Hệ thống quản lý sản phẩm Mongoose & Express</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
          <div class="d-flex gap-3 justify-content-md-end align-items-center flex-wrap">
            <button class="btn btn-primary d-flex align-items-center gap-2 px-4 py-2 shadow-sm rounded-3"
              onclick="openAddModal()">
              <i class="bi bi-plus-circle-fill"></i>
              <span>Thêm sản phẩm</span>
            </button>
            <div class="text-center bg-light border p-2 rounded-3 min-vw-10">
              <div class="fw-700 fs-4 h-1 px-2" id="statFiltered">0</div>
              <div class="small text-muted text-uppercase fw-600">Kết quả</div>
            </div>
            <div class="text-center bg-light border p-2 rounded-3 min-vw-10">
              <div class="fw-700 fs-4 h-1 px-2" id="statTotal">0</div>
              <div class="small text-muted text-uppercase fw-600">Tổng SP</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Controls Row -->
    <div class="bg-white rounded-4 shadow-sm p-4 mb-4 border">
      <div class="row g-3 align-items-center">
        <!-- Search -->
        <div class="col-md-5">
          <label class="form-label fw-600 small text-muted mb-1 text-uppercase">Tìm kiếm</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0">
              <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" class="form-control bg-light border-start-0 ps-0" id="searchInput"
              placeholder="Nhập tên sản phẩm..." />
            <button class="btn btn-outline-secondary d-none" id="clearSearch" type="button">
              <i class="bi bi-x"></i>
            </button>
          </div>
        </div>

        <!-- Limit -->
        <div class="col-md-3">
          <label class="form-label fw-600 small text-muted mb-1 text-uppercase">Dòng/Trang</label>
          <select class="form-select bg-light" id="limitSelect">
            <option value="5">5 sản phẩm</option>
            <option value="10" selected>10 sản phẩm</option>
            <option value="20">20 sản phẩm</option>
          </select>
        </div>

        <!-- Sort -->
        <div class="col-md-4">
          <label class="form-label fw-600 small text-muted mb-1 text-uppercase">Sắp xếp</label>
          <div class="d-flex gap-2">
            <button class="btn btn-light border flex-fill fw-600 text-muted" onclick="toggleSort('title')">
              Tên <i class="bi bi-arrow-down-up ms-1 small" id="sortTitleIcon"></i>
            </button>
            <button class="btn btn-light border flex-fill fw-600 text-muted" onclick="toggleSort('price')">
              Giá <i class="bi bi-arrow-down-up ms-1 small" id="sortPriceIcon"></i>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Table Card -->
    <div class="bg-white rounded-4 shadow-sm border overflow-hidden">
      <!-- Loading -->
      <div id="loadingSpinner" class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Đang tải...</p>
      </div>

      <!-- Error -->
      <div id="errorState" class="text-center py-5 d-none">
        <i class="bi bi-exclamation-triangle display-4 text-danger"></i>
        <h5 class="mt-2">Lỗi tải dữ liệu</h5>
        <button class="btn btn-sm btn-outline-primary mt-2" onclick="fetchProducts()">Thử lại</button>
      </div>

      <!-- Empty -->
      <div id="emptyState" class="text-center py-5 d-none">
        <i class="bi bi-inbox display-4 text-muted"></i>
        <h5 class="mt-2 text-muted">Không có dữ liệu</h5>
      </div>

      <!-- Table -->
      <div id="tableWrapper" class="d-none">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
              <tr class="text-uppercase small fw-700 text-muted">
                <th class="ps-4" style="width:60px">#</th>
                <th style="width:80px">Ảnh</th>
                <th>Sản phẩm</th>
                <th>Giá</th>
                <th>Danh mục</th>
                <th class="pe-4" style="width:120px text-end">Thao tác</th>
              </tr>
            </thead>
            <tbody id="tableBody"></tbody>
          </table>
        </div>
        <div class="p-4 border-top bg-light d-flex align-items-center justify-content-between flex-wrap gap-3">
          <div class="small text-muted" id="paginationInfo"></div>
          <nav>
            <ul class="pagination pagination-sm mb-0" id="paginationUl"></ul>
          </nav>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content rounded-4 border-0 shadow">
        <div class="modal-header border-0 pb-0">
          <h5 class="fw-700" id="modalTitle"></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <form id="productForm">
            <input type="hidden" id="productId">
            <div class="mb-3">
              <label class="form-label small fw-700 text-muted text-uppercase">Tên sản phẩm</label>
              <input type="text" class="form-control rounded-3" id="titleInput" required>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label small fw-700 text-muted text-uppercase">Giá ($)</label>
                <input type="number" class="form-control rounded-3" id="priceInput" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label small fw-700 text-muted text-uppercase">Category ID (ObjectId)</label>
                <input type="text" class="form-control rounded-3" id="catIdInput" required
                  placeholder="Paste ObjectId here">
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label small fw-700 text-muted text-uppercase">Ảnh (URL)</label>
              <input type="url" class="form-control rounded-3" id="imageInput" required>
            </div>
            <div class="mb-0">
              <label class="form-label small fw-700 text-muted text-uppercase">Mô tả</label>
              <textarea class="form-control rounded-3" id="descInput" rows="3" required></textarea>
            </div>
          </form>
        </div>
        <div class="modal-footer border-0 p-4 pt-0">
          <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Hủy</button>
          <button type="button" class="btn btn-primary px-4 fw-600 rounded-3" onclick="saveProduct()">Lưu</button>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="liveToast" class="toast align-items-center text-white bg-dark border-0 shadow" role="alert">
      <div class="d-flex">
        <div class="toast-body fw-600" id="toastMessage"></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  </div>

  <div id="descTooltip" class="custom-tooltip">
    <div class="fw-700 small mb-1">Mô tả chi tiết:</div>
    <div id="descTooltipBody"></div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/javascripts/dashboard.js"></script>
</body>

</html>